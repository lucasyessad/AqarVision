# =============================================================================
# AqarVision — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# =============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AqarVision

# IA — Anthropic Claude (requis pour génération de descriptions)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Emails transactionnels — Resend (requis pour les alertes et notifications)
RESEND_API_KEY=your-resend-api-key

# API publique (clé pour les partenaires)
PUBLIC_API_KEY=your-public-api-key

# Sentry — Monitoring d'erreurs (optionnel)
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Réseaux sociaux (optionnel — pour les feeds sociaux des agences)
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
