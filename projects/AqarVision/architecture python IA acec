## 8. Intégration côté Next.js

### Modification de ai.service.ts

```typescript
// features/ai/services/ai.service.ts

const AI_BACKEND_URL = process.env.AI_BACKEND_URL || "http://localhost:8000";
const AI_SERVICE_KEY = process.env.AI_SERVICE_KEY;

async function callAIBackend<T>(
  endpoint: string,
  body: Record<string, unknown>
): Promise<T> {
  const response = await fetch(`${AI_BACKEND_URL}/api/v1/${endpoint}`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "X-Service-Key": AI_SERVICE_KEY!,
    },
    body: JSON.stringify(body),
  });

  if (!response.ok) {
    const error = await response.json();
    throw new Error(error.detail || "AI Backend error");
  }

  return response.json() as T;
}

// Génération de titre
export async function generateTitle(listingData: ListingData, photoUrls?: string[]) {
  return callAIBackend<GenerateTitleResponse>("generate/title", {
    property_type: listingData.propertyType,
    transaction_type: listingData.transactionType,
    surface: listingData.surface,
    rooms: listingData.rooms,
    // ...autres champs
    photos: photoUrls,
  });
}

// Génération de description
export async function generateDescription(listingData: ListingData, photoUrls?: string[]) {
  return callAIBackend<GenerateDescriptionResponse>("generate/description", {
    ...listingData,
    photos: photoUrls,
  });
}

// Analyse de photos
export async function analyzePhotos(photoUrls: string[]) {
  return callAIBackend<AnalyzePhotosResponse>("analyze/photos", {
    photos: photoUrls,
  });
}

// Estimation de prix
export async function estimatePrice(propertyData: PropertyData) {
  return callAIBackend<EstimatePriceResponse>("estimate/price", propertyData);
}
```

