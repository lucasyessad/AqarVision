## 4. Service Claude Client

```python
# services/claude_client.py

import anthropic
import base64
from config import settings

class ClaudeClient:
    def __init__(self):
        self.client = anthropic.Anthropic(api_key=settings.ANTHROPIC_API_KEY)
        self.model = "claude-sonnet-4-20250514"  # Sonnet pour la vitesse
        self.model_heavy = "claude-sonnet-4-20250514"  # Opus pour les tâches complexes

    async def generate_text(
        self,
        prompt: str,
        system: str = "",
        max_tokens: int = 1000,
        temperature: float = 0.7,
    ) -> str:
        """Génération de texte simple."""
        response = self.client.messages.create(
            model=self.model,
            max_tokens=max_tokens,
            system=system,
            messages=[{"role": "user", "content": prompt}],
        )
        return response.content[0].text

    async def analyze_image(
        self,
        image_url: str,
        prompt: str,
        system: str = "",
    ) -> str:
        """Analyse d'une image via Claude Vision."""
        # Télécharger l'image depuis Supabase Storage
        image_data = await self._download_image(image_url)
        image_base64 = base64.standard_b64encode(image_data).decode("utf-8")
        media_type = self._detect_media_type(image_data)

        response = self.client.messages.create(
            model=self.model,
            max_tokens=1000,
            system=system,
            messages=[{
                "role": "user",
                "content": [
                    {
                        "type": "image",
                        "source": {
                            "type": "base64",
                            "media_type": media_type,
                            "data": image_base64,
                        },
                    },
                    {"type": "text", "text": prompt},
                ],
            }],
        )
        return response.content[0].text

    async def analyze_multiple_images(
        self,
        image_urls: list[str],
        prompt: str,
        system: str = "",
    ) -> str:
        """Analyse de plusieurs images en un seul appel."""
        content = []
        for url in image_urls[:10]:  # Max 10 images par appel
            image_data = await self._download_image(url)
            image_base64 = base64.standard_b64encode(image_data).decode("utf-8")
            media_type = self._detect_media_type(image_data)
            content.append({
                "type": "image",
                "source": {
                    "type": "base64",
                    "media_type": media_type,
                    "data": image_base64,
                },
            })
        content.append({"type": "text", "text": prompt})

        response = self.client.messages.create(
            model=self.model,
            max_tokens=2000,
            system=system,
            messages=[{"role": "user", "content": content}],
        )
        return response.content[0].text
```

